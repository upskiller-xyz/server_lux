# Deployment Configuration
# Set to 'local' for Docker Compose deployment, 'production' for GCP Cloud Run
DEPLOYMENT_MODE=local

# API Authentication
# AUTH_TYPE: Authentication method to use (token, auth0, none)
# - token: Simple bearer token authentication (default for production)
# - auth0: Auth0 JWT-based authentication (recommended for production)
# - none: No authentication required - Community Edition (local development only)
# For community/local version without authentication, set: AUTH_TYPE=none
AUTH_TYPE=none

# Token Authentication (when AUTH_TYPE=token)
# Used for both incoming request authentication and outgoing requests to GCP microservices
# If API_TOKEN is not set or empty, token authentication will be disabled (allows all requests)
# In development: Required when calling GCP Cloud Run services from localhost
# In production: Services authenticate automatically within the same GCP project
# API_TOKEN=your_secret_token_here

# Auth0 Configuration (when AUTH_TYPE=auth0)
# AUTH0_DOMAIN: Your Auth0 tenant domain (e.g., your-tenant.auth0.com or your-tenant.us.auth0.com)
# AUTH0_AUDIENCE: The identifier for your API in Auth0 (e.g., https://api.yourdomain.com)
# AUTH0_ALGORITHMS: Comma-separated list of allowed algorithms (default: RS256)
# AUTH0_DOMAIN=your-tenant.auth0.com
# AUTH0_AUDIENCE=https://api.yourdomain.com
# AUTH0_ALGORITHMS=RS256

# Docker Images (GCP Artifact Registry)
# Override these if using different image versions or registries
# COLORMANAGE_IMAGE=europe-north2-docker.pkg.dev/daylight-factor/daylight-server-docker-repo/daylight-colormanage-img:latest
# DAYLIGHT_IMAGE=europe-north2-docker.pkg.dev/daylight-factor/daylight-server-docker-repo/daylight-model-img:latest
# METRICS_IMAGE=europe-north2-docker.pkg.dev/daylight-factor/daylight-server-docker-repo/daylight-metrics-img:latest
# OBSTRUCTION_IMAGE=europe-north2-docker.pkg.dev/daylight-factor/daylight-server-docker-repo/daylight-obstruction-img:latest
# ENCODER_IMAGE=europe-north2-docker.pkg.dev/daylight-factor/daylight-server-docker-repo/daylight-encoder-img:latest
# POSTPROCESS_IMAGE=europe-north2-docker.pkg.dev/daylight-factor/daylight-server-docker-repo/daylight-postprocess-img:latest

# Local Deployment Service URLs (Docker Compose)
# These are used when DEPLOYMENT_MODE=local
# Override these if using custom service names or ports
COLORMANAGE_SERVICE_URL=http://colormanage:8080
DAYLIGHT_SERVICE_URL=http://daylight:8080
DF_EVAL_SERVICE_URL=http://metrics:8080
# Obstruction service. Point at the local container, OR at a private Scaleway
# serverless container to run the CPU-bound obstruction bursts elastically. The
# URL is the only switch: a host ending in ".scw.cloud" is auto-detected and the
# invocation token (X-Auth-Token) is attached from SCW_CONTAINER_TOKEN below.
OBSTRUCTION_SERVICE_URL=http://obstruction:8080
# Scaleway serverless example:
# OBSTRUCTION_SERVICE_URL=https://<name>-<hash>.functions.fnc.fr-par.scw.cloud
# Scaleway serverless auth token. Required whenever OBSTRUCTION_SERVICE_URL is a
# *.scw.cloud URL — lux attaches it to every call and raises if it is unset for
# such a URL. Generate it for the container in the Scaleway console/API.
# SCW_CONTAINER_TOKEN=...
# Max concurrent in-flight obstruction requests per lux process (backpressure).
# Set to the backend's ceiling — e.g. Scaleway serverless max-instances. Default 10.
# OBSTRUCTION_MAX_CONCURRENCY=10
# Encoder runs on same host as main server (localhost:8082)
ENCODER_SERVICE_URL=http://localhost:8082
# Model server (inference). Point this at the container (e.g. the GPU VM) OR at a
# Modal endpoint to run inference serverlessly on Modal. The URL is the only switch:
# a host ending in ".modal.run" is auto-detected and proxy-auth headers
# (Modal-Key/Modal-Secret) are attached from MODAL_KEY/MODAL_SECRET below.
# Container example:
MODEL_SERVICE_URL=http://51.15.197.220:8083
# Modal example (from `modal deploy -m modal_app.app`):
# MODEL_SERVICE_URL=https://<workspace>--upskiller-model-inferenceservice-web.modal.run

# Modal proxy-auth credentials (required only when MODEL_SERVICE_URL is a *.modal.run URL).
# Create a proxy-auth token in the Modal dashboard and set both values.
# MODAL_KEY=wk-...
# MODAL_SECRET=ws-...
# Merger service (for local debugging, use http://localhost:8084)
MERGER_SERVICE_URL=http://merger:8084
POSTPROCESS_SERVICE_URL=http://postprocess:8080

# Production Service URLs (GCP Cloud Run)
# These are used when DEPLOYMENT_MODE=production
# Override these if your production URLs differ
# COLORMANAGE_SERVICE_URL=https://colormanage-server-182483330095.europe-north2.run.app
# DAYLIGHT_SERVICE_URL=https://daylight-factor-182483330095.europe-north2.run.app
# DF_EVAL_SERVICE_URL=https://df-eval-server-182483330095.europe-north2.run.app
# OBSTRUCTION_SERVICE_URL=https://obstruction-server-182483330095.europe-north2.run.app
# ENCODER_SERVICE_URL=https://encoder-server-182483330095.europe-north2.run.app
# POSTPROCESS_SERVICE_URL=https://daylight-processing-182483330095.europe-north2.run.app

# Server Configuration
PORT=8080
