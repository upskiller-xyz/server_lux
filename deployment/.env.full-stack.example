# Full Stack Environment Configuration
# Copy this file to .env.full-stack and fill in your values

# Service Configuration
WORKERS=1
THREADS=8

# Deployment Mode
DEPLOYMENT_MODE=local

# Service URLs (override defaults to use container names in Docker network)
ENCODER_SERVICE_URL=http://encoder-service:8082
MODEL_SERVICE_URL=http://model-service:8083
MERGER_SERVICE_URL=http://merger-service:8084
OBSTRUCTION_SERVICE_URL=http://obstruction-service:8081
STATS_SERVICE_URL=http://stats-service:8085

# Model S3 access (Scaleway private bucket)
MODEL_URL_TEMPLATE=s3://your-bucket-name/models/{name}.onnx
# Specs are fetched from s3://{bucket}/{name}/spec.json by default — set SPEC_URL_TEMPLATE to override
SCW_ACCESS_KEY=your-scaleway-access-key
SCW_SECRET_KEY=your-scaleway-secret-key
SCW_REGION=your-region
SCW_ENDPOINT_URL=https://s3.your-region.your-provider.cloud

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False

# Logging
LOG_LEVEL=INFO

# Debug: save intermediate pipeline images to ./debug_output on the host
# Set to true to enable, false (default) to disable
DEBUG_SAVE_IMAGES=false

# Performance Optimizations
CUDA_VISIBLE_DEVICES=-1
TF_CPP_MIN_LOG_LEVEL=3
OPENCV_IO_ENABLE_OPENEXR=0
OMP_NUM_THREADS=1
