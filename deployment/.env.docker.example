# Docker environment configuration for Server Lux
# Copy this file to .env.docker and fill in your values

# Server configuration
PORT=8080
WORKERS=4
THREADS=8
TIMEOUT=900

# Flask configuration
FLASK_ENV=production
FLASK_DEBUG=False

# Gunicorn configuration
GUNICORN_LOG_LEVEL=info

# Performance optimizations
CUDA_VISIBLE_DEVICES=-1
TF_CPP_MIN_LOG_LEVEL=3
OPENCV_IO_ENABLE_OPENEXR=0
OMP_NUM_THREADS=1

# Telemetry (fire-and-forget emission to server_telemetry; disabled if URL unset)
TELEMETRY_SERVICE_URL=http://telemetry:8086
TELEMETRY_ENABLED=true
TELEMETRY_TIMEOUT_SECONDS=2
# TELEMETRY_IDENTITY_MODE=anonymous
# Secret salt used by the telemetry container (keep stable and secret)
TELEMETRY_HMAC_SALT=change_me_to_a_long_random_secret
