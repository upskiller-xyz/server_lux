# Scaleway full-stack deployment — Modal inference + internal-only services.
#
# NON-SECRET config only. The CI deploy (.github/workflows/deploy-scaleway.yml)
# renders the .env.scaleway used at runtime by APPENDING secrets from GitHub
# Secrets to this template — so no secret values live in the repo and nothing is
# edited by hand on the box.
#
# Secrets injected by CI (do NOT add them here): MODAL_KEY, MODAL_SECRET,
# API_TOKEN, SCW_ACCESS_KEY, SCW_SECRET_KEY. Set them in GitHub → Settings →
# Secrets and variables → Actions.
#
# For a manual/local deploy instead, copy this to .env.scaleway and add the
# secret values yourself (.env.scaleway is gitignored).

# ── Inference on Modal ───────────────────────────────────────────────────────
# Point at the deployed Modal endpoint. A *.modal.run host is auto-detected and
# server-lux attaches Modal-Key / Modal-Secret proxy-auth headers automatically.
# In CI, override this with the `MODEL_SERVICE_URL` GitHub Variable.
MODEL_SERVICE_URL=https://<workspace>--upskiller-model-inferenceservice-web.modal.run

# ── Public API auth (inbound, optional) ──────────────────────────────────────
# none = open (Community); token = require `Authorization: Bearer <API_TOKEN>`;
# auth0 = validate Auth0-issued JWTs (Bearer) against the tenant's JWKS.
# NOTE: token auth is only enforced when API_TOKEN is non-empty. With
# AUTH_TYPE=token but no API_TOKEN, a missing/malformed Authorization header is
# still rejected, but the token value is NOT checked — any `Bearer <anything>`
# is accepted. The CI deploy fails fast on that combination; for a manual deploy,
# make sure you set API_TOKEN when AUTH_TYPE=token.
# Set AUTH_TYPE via the `AUTH_TYPE` GitHub Variable; API_TOKEN via GitHub Secrets.
AUTH_TYPE=none

# Auth0 (only when AUTH_TYPE=auth0). These are PUBLIC identifiers, not secrets —
# set them as GitHub Variables (the CI deploy renders them). lux validates the
# JWT signature/audience/issuer; it never needs an Auth0 client secret (it is the
# resource server, not a token-requesting client). issuer + JWKS URL are derived
# from AUTH0_DOMAIN. AUTH0_ALGORITHMS is optional (default RS256).
# AUTH0_DOMAIN=your-tenant.eu.auth0.com
# AUTH0_AUDIENCE=https://api.your-service/
# AUTH0_ALGORITHMS=RS256

# ── Per-service resources & workers ──────────────────────────────────────────
# Obstruction is the heaviest CPU service: server-lux sends one request per window
# and the service computes all 64 directions internally (vectorized ray casting).
# Concurrency into it ≈ (concurrent user requests) × (windows per request). Scale
# WORKERS/CPUS up if you serve many simultaneous requests (prod has run WORKERS=32).
OBSTRUCTION_WORKERS=4
OBSTRUCTION_THREADS=2
OBSTRUCTION_CPUS=4
OBSTRUCTION_MEM=4g

LUX_WORKERS=2
LUX_THREADS=8
LUX_CPUS=2
LUX_MEM=2g

ENCODER_WORKERS=2
ENCODER_THREADS=4
ENCODER_CPUS=2
ENCODER_MEM=2g

MERGER_WORKERS=2
MERGER_THREADS=4
MERGER_CPUS=1
MERGER_MEM=1g

STATS_WORKERS=1
STATS_THREADS=4
STATS_CPUS=1
STATS_MEM=1g

# ── Performance / runtime tuning (CPU-only box) ──────────────────────────────
CUDA_VISIBLE_DEVICES=-1
TF_CPP_MIN_LOG_LEVEL=3
OMP_NUM_THREADS=1
LOG_LEVEL=INFO

# ── Scaleway Container Registry (OPTIONAL) ───────────────────────────────────
# The default deploy builds images on the instance (deploy-scaleway.sh supports
# only --build and --firewall) and does NOT use a registry. These are only for a
# separate build/push workflow; leave unset for the standard on-box build.
# SCW_REGISTRY=rg.fr-par.scw.cloud/your-namespace
# SCW_REGISTRY_USER=nologin
# Registry auth would use SCW_SECRET_KEY (inject via GitHub Secrets if you add such a flow).
