# Scaleway full-stack deployment — Modal inference + internal-only services.
# Copy to .env.scaleway and fill in the values.

# ── Inference on Modal ───────────────────────────────────────────────────────
# Point at the deployed Modal endpoint. A *.modal.run host is auto-detected and
# server-lux attaches Modal-Key / Modal-Secret proxy-auth headers automatically.
MODEL_SERVICE_URL=https://<workspace>--upskiller-model-inferenceservice-web.modal.run
# Proxy-auth token from the Modal dashboard (required for the *.modal.run URL above).
MODAL_KEY=wk-...
MODAL_SECRET=ws-...

# ── GitHub access for cloning the private microservice repos ──────────────────
# GitHub no longer accepts login/password over HTTPS. Either set a token here, or
# run `gh auth login` + `gh auth setup-git` once and leave this blank.
# Token needs read access to the upskiller-xyz repos (classic: `repo`; fine-grained:
# Contents:Read). It is used per git call and never written to disk.
# GITHUB_TOKEN=ghp_...

# ── Cloudflare (used by setup-cloudflare.sh to automate DNS + TLS) ────────────
# Run `bash setup-cloudflare.sh` once to upsert the DNS record, set SSL mode to
# Full (strict), and issue the Origin cert into certs/. All optional — you can
# still do these by hand in the dashboard and just drop certs/origin.{pem,key}.
DOMAIN=api.yourdomain.com
# CF_API_TOKEN=...        # token with Zone:DNS:Edit + Zone Settings:Edit
# CF_ZONE_ID=...          # zone id for yourdomain.com
# CF_ORIGIN_CA_KEY=...    # Origin CA Key (only needed to auto-issue the cert)
# SERVER_IP=              # optional; auto-detected if left blank

# ── Public API auth (inbound) ────────────────────────────────────────────────
# none = open; token = require `Authorization: Bearer <API_TOKEN>`; auth0 = JWT (prod).
AUTH_TYPE=auth0
# When AUTH_TYPE=token:
# API_TOKEN=your_public_api_token
# When AUTH_TYPE=auth0 (required — server refuses to start without domain+audience):
AUTH0_DOMAIN=upskiller.eu.auth0.com
AUTH0_AUDIENCE=https://lux-api.upskiller.xyz
AUTH0_ALGORITHMS=RS256

# ── Per-service resources & workers ──────────────────────────────────────────
# Obstruction is the heaviest CPU service: server-lux sends one request per window
# and the service computes all 64 directions internally (vectorized ray casting).
# Concurrency into it ≈ (concurrent user requests) × (windows per request). Scale
# WORKERS/CPUS up if you serve many simultaneous requests (prod has run WORKERS=32).
OBSTRUCTION_WORKERS=4
OBSTRUCTION_THREADS=2
OBSTRUCTION_CPUS=4
OBSTRUCTION_MEM=4g

LUX_WORKERS=2
LUX_THREADS=8
LUX_CPUS=2
LUX_MEM=2g

ENCODER_WORKERS=2
ENCODER_THREADS=4
ENCODER_CPUS=2
ENCODER_MEM=2g

MERGER_WORKERS=2
MERGER_THREADS=4
MERGER_CPUS=1
MERGER_MEM=1g

STATS_WORKERS=1
STATS_THREADS=4
STATS_CPUS=1
STATS_MEM=1g

# ── Performance / runtime tuning (CPU-only box) ──────────────────────────────
CUDA_VISIBLE_DEVICES=-1
TF_CPP_MIN_LOG_LEVEL=3
OMP_NUM_THREADS=1
LOG_LEVEL=INFO

# ── Scaleway Container Registry (only if you build/push images instead of
#    building on the instance). Used by deploy-scaleway.sh --registry. ─────────
# SCW_REGISTRY=rg.fr-par.scw.cloud/your-namespace
# SCW_REGISTRY_USER=nologin
# SCW_SECRET_KEY=your-scaleway-secret-key
